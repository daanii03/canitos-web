---
export interface Props {
  title?: string;
  justify?: "start" | "center";
}

const { title, justify = "center" } = Astro.props;

import "@fontsource/eb-garamond/400.css"; // Regular
import "@fontsource/eb-garamond/700.css"; // Bold
import "@fontsource/hanken-grotesk/400.css";
import "@fontsource/hanken-grotesk/700.css";
import "../styles/global.css";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import MobileNav from "@components/MobileNav.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="font-sans flex flex-col min-h-screen bg-base">
    <Header />
    <main class={`flex-1 flex flex-col ${justify === "start" ? "justify-start" : "justify-center"} items-center`}>
      <slot />
    </main>
    <Footer />
    <MobileNav />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }
</style>
